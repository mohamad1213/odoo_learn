<odoo>
    <!-- Action -->
    <record id="estate_property_tag_action" model="ir.actions.act_window">
        <!-- nama menunya  -->
        <field name="name">Property Tags</field>
        <field name="res_model">estate.property.tag</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Search and filter -->
     <record id="estate-property_tag_view_search_filter" model="ir.ui.view">
        <field name="name">estate.property.tag.view.search.filter</field>
        <field name="model">estate.property.tag</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
     </record>

    <record id="estate_property_tag_tree_view" model="ir.ui.view">
        <field name="name">estate.property.tag.view.tree</field>
        <field name="model">estate.property.tag</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
            </tree>
        </field>
    </record>

    <record id="estate_property_tag_form_view" model="ir.ui.view">
        <field name="name">estate.property.tag.view.form</field>
        <field name="model">estate.property.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
