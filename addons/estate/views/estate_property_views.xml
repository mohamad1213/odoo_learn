<odoo>
    <!-- Action -->
    <record id="estate_property_action" model="ir.actions.act_window">
        <!-- nama menunya  -->
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Search and filter -->
     <record id="estate-property_view_search_filter" model="ir.ui.view">
        <field name="name">estate.property.view.search.filter</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="postcode"/>
                <field name="expected_price"/>
                <field name="bedrooms"/>
                <field name="living_area"/>
                <field name="facades"/>
                <filter name="state" string="Available" domain="[('state', 'in', ['new', 'offer_received'])]" />
                <!-- Grouping by postcode -->
                <filter name="postcode" string="Postcode" context="{'group_by': 'postcode'}" /> 
            </search>
        </field>
     </record>
     <!-- Tree -->
    <record id="estate_property_tree_view" model="ir.ui.view">
        <field name="name">estate.property.view.tree</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <!-- Menampilkan data dalam bentuk tabel (tree view) dengan kolom-kolom yang ditentukan. 
            ada dua cari yaitu dari xml atau dari modelsnya 

            jika dari xml menggunakan string seperti ini <field name="name" string="Title"/>
            sedangkan jika di models menggunakan field name seperti ini name = fields.Char("Title",
            required=True) -->
            <tree>
                <field name="name" string="Title" />
                <field name="postcode" string="Postcode" />
                <field name="bedrooms" string="Bedrooms" />
                <field name="living_area" string="Living Area (sqm)" />
                <field name="expected_price" string="Expected Price" />
                <field name="selling_price" string="Selling Price" />
                <field name="date_availability" string="Available From" />
                <field name="state" string="Status" />
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="estate_property_form_view" model="ir.ui.view">
        <field name="name">estate.property.view.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="postcode" />
                            <field name="date_availability" />
                            <!-- membuat field muncul ketika di base model -->
                            <field name="state" groups="base.group_no_one" />
                        </group>
                        <group>
                            <field name="expected_price" />
                            <field name="selling_price" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Property Details">
                            <field name="description" string="Description" />
                            <field name="bedrooms" string="Bedrooms" />
                            <field name="living_area" string="Living Area (sqm)" />
                            <field name="facades" string="Facades" />
                            <field name="garage" string="Garage" />
                            <field name="garden" string="Garden" />
                            <field name="garden_area" string="Garden Area (sqm)" />
                            <field name="garden_orientation" string="Garden Orientation" />
                        </page>
                        <page string="Active">
                            <group>
                                <field name="active" />
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>